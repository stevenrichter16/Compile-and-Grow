--- !u!114 &631933629
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 631933628}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 8fc4e6132bacb4b049aa42ee75a07220, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::OrganismEntity
  organismName: Sunfern
  growlSource: "fn photosynthesis():\n    water = org_get(\"water\", 0)\n    if water
    > 0.1:\n        gain = 3.5 * water\n        org_add(\"energy\", gain)\n       
    org_add(\"water\", -0.04)\n    else:\n        org_add(\"stress\", 0.1)\n\nfn
    respiration():\n    org_add(\"energy\", -0.6)\n\nfn grow():\n    energy = org_get(\"energy\",
    0)\n    maturity = org_get(\"maturity\", 0)\n    if energy > 5 and maturity <
    1.0:\n        growth = 0.03\n        if energy > 15:\n            growth = 0.06\n       
    org_add(\"maturity\", growth)\n        org_add(\"energy\", -0.8)\n\nfn water_uptake():\n   
    water = org_get(\"water\", 0)\n    if water < 1.0:\n        org_add(\"water\",
    0.06)\n\nfn stress_check():\n    energy = org_get(\"energy\", 0)\n    water =
    org_get(\"water\", 0)\n    stress = org_get(\"stress\", 0)\n    if energy < 3:\n       
    org_add(\"stress\", 0.08)\n        org_damage(0.03)\n    if water < 0.15:\n       
    org_add(\"stress\", 0.06)\n        org_damage(0.02)\n    if energy > 8 and water
    > 0.3:\n        if stress > 0:\n            org_add(\"stress\", -0.05)\n       
    org_heal(0.01)\n\nfn reproduce():\n    maturity = org_get(\"maturity\", 0)\n   
    energy = org_get(\"energy\", 0)\n    if maturity >= 0.8 and energy > 12:\n       
    spawn_seed(1)\n        org_add(\"energy\", -5)\n        emit_signal(\"seed_drop\",
    intensity: 0.6, radius: 2)\n\nfn main():\n    org_add(\"age\", 1)\n    photosynthesis()\n   
    respiration()\n    water_uptake()\n    grow()\n    stress_check()\n    reproduce()\n   
    age = org_get(\"age\")\n    energy = org_get(\"energy\")\n    water = org_get(\"water\")\n   
    maturity = org_get(\"maturity\")\n    health = org_get(\"health\")\n    stress
    = org_get(\"stress\")\n    print(\"age:\", age, \"energy:\", energy, \"water:\",
    water, \"maturity:\", maturity, \"health:\", health, \"stress:\", stress)"
  alive: 1
  age: 0
  maturity: 0
  energy: 15
  water: 0.7
  health: 1
  stress: 0
